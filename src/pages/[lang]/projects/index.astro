---
import { LOCALES, useTranslations, type Lang } from "@/i18n";
import Layout from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import PageHeadline from "@/components/PageHeadline.astro";

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const projects = (await getCollection("projects"))
    .filter((project) => project.id.split("/")[0] === locale)
    .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const title = t({
    ja: "プロジェクト",
    en: "Projects",
    "zh-cn": "项目",
    ar: "مشاريع",
});

const description = t({
    en: "Explore Frency's independent products, websites, and software projects.",
    "zh-cn": "查看小峰的独立产品、网站与软件项目。",
});

export const getStaticPaths = () =>
    Object.keys(LOCALES).map((lang) => ({
        params: { lang },
    }));
---

<Layout {title} {description}>
    <PageHeadline {title} />

    <ul>
        {
            projects.map((project) => {
                const [, ...id] = project.id.split("/");
                return (
                    <li>
                        <a href={`/${locale}/projects/${id.join("/")}/`}>
                            {project.data.cover && (
                                <Image
                                    src={project.data.cover}
                                    alt={project.data.title}
                                />
                            )}
                            <div class="project-copy">
                                <time datetime={project.data.date.toISOString()}>{project.data.date.toLocaleDateString(locale)}</time>
                                <h2>{project.data.title}</h2>
                                <p>{project.data.description}</p>
                            </div>
                        </a>
                    </li>
                );
            })
        }
    </ul>
</Layout>

<style>
    ul {
        margin-block-start: var(--sp-l);
        display: grid;
        gap: 24px;
        grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    }

    li a {
        display: block;
        height: 100%;
        overflow: hidden;
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        background: var(--color-surface);
    }
    li a:hover { border-color: var(--color-theme); background: var(--color-surface-high); }
    li img { width: 100%; aspect-ratio: 16 / 9; border-radius: 0; object-fit: cover; }
    .project-copy { padding: 24px; }
    time { color: var(--color-faint); font-family: var(--font-mono); font-size: 0.75rem; }
    h2 { margin-top: 8px; font-size: 1.45rem; }
    p { color: var(--color-muted); font-size: 0.95rem; line-height: 1.65; }
    @media (max-width: 640px) {
        ul { grid-template-columns: 1fr; margin-top: 32px; }
    }
</style>
