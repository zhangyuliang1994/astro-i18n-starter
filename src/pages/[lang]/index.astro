---
import { LOCALES, useTranslations, type Lang } from "@/i18n";
import Layout from "@/layouts/Base.astro";
const t = useTranslations(Astro.currentLocale as Lang);
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const locale = Astro.currentLocale as Lang;

const posts = (await getCollection("blog"))
  .filter((post) => post.id.split("/")[0] === locale)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3); // Get top 3 latest posts

export const getStaticPaths = () =>
  Object.keys(LOCALES).map((lang) => ({
    params: { lang },
  }));
---

<Layout>
  <div class="hero-container">
    <div class="hero-card">
      <h1 class="hero-title">
        {
          locale === "en" ? (
            <span class="domain-text">frency.me</span>
          ) : (
            <span class="domain-text">xiaofeng.show</span>
          )
        }
      </h1>
      <p class="hero-subtitle">
        {
          t({
            en: "Welcome to my digital garden.",
            "zh-cn": "欢迎来到我的数字花园。",
            ja: "私のデジタルガーデンへようこそ。",
            ar: "مرحبا بكم في حديقتي الرقمية.",
          })
        }
      </p>
    </div>
  </div>

  <section class="latest-posts">
    <div class="section-header">
      <h2>
        {
          t({
            en: "Latest Posts",
            "zh-cn": "最新文章",
            ja: "最新の投稿",
            ar: "أحدث المشاركات",
          })
        }
      </h2>
      <a href={getRelativeLocaleUrl(locale, "/blog")} class="view-all">
        {
          t({
            en: "View All",
            "zh-cn": "查看全部",
            ja: "すべて見る",
            ar: "عرض الكل",
          })
        }
        <span class="material-icons-sharp">arrow_forward</span>
      </a>
    </div>

    <ul class="post-list">
      {
        posts.map((post) => {
          const [, ...id] = post.id.split("/");
          return (
            <li>
              <a href={`/${locale}/blog/${id.join("/")}/`} class="post-card">
                {post.data.cover && (
                  <div class="post-image-container">
                    <Image src={post.data.cover} alt={post.data.title} />
                  </div>
                )}
                <div class="post-content">
                  <h3>{post.data.title}</h3>
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString(locale)}
                  </time>
                  <p>{post.data.description}</p>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>

  <section class="quick-links">
    <a href={getRelativeLocaleUrl(locale, "/tags")} class="quick-link-card">
      <span class="material-icons-sharp icon">label</span>
      <h3>{t({ en: "Tags", "zh-cn": "标签", ja: "タグ", ar: "الوسوم" })}</h3>
    </a>
    <a
      href={getRelativeLocaleUrl(locale, "/categories")}
      class="quick-link-card"
    >
      <span class="material-icons-sharp icon">category</span>
      <h3>
        {
          t({
            en: "Categories",
            "zh-cn": "分类",
            ja: "カテゴリー",
            ar: "التصنيفات",
          })
        }
      </h3>
    </a>
    <a href={getRelativeLocaleUrl(locale, "/about")} class="quick-link-card">
      <span class="material-icons-sharp icon">person</span>
      <h3>{t({ en: "About", "zh-cn": "关于", ja: "約", ar: "حول" })}</h3>
    </a>
  </section>
</Layout>

<style>
  .hero-container {
    display: grid;
    min-height: clamp(320px, 48vw, 500px);
    align-items: center;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-card {
    position: relative;
    max-width: 900px;
    padding-left: clamp(20px, 6vw, 72px);
  }

  .hero-card::before {
    content: "/";
    position: absolute;
    top: 0.18em;
    left: 0;
    color: var(--color-theme);
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
  }

  .hero-title {
    margin: 0;
    color: var(--color-main);
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 800;
    letter-spacing: -0.07em;
    line-height: 0.95;
    font-family: var(--font-interface);
  }

  .domain-text {
    color: inherit;
  }

  .hero-subtitle {
    max-width: 620px;
    margin-top: 24px;
    color: var(--color-muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .latest-posts { padding-block: var(--sp-xl) var(--sp-l); }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }

  h2 {
    color: var(--color-main);
    font-size: 1.65rem;
  }

  .view-all {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 600;
    color: var(--color-theme);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .view-all:hover {
    opacity: 0.7;
  }

  .post-list {
    display: grid;
    gap: 24px;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    list-style: none;
    padding: 0;
  }

  .post-card {
    display: block;
    height: 100%;
    background: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.2s,
      background-color 0.2s;
    border: 1px solid var(--color-border);
  }

  .post-card:hover {
    border-color: var(--color-theme);
    background: var(--color-surface-high);
  }

  .post-image-container {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .post-image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-content {
    padding: 1.5rem;
  }

  .post-content h3 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-main);
  }

  .post-content time {
    display: block;
    font-size: 0.9rem;
    color: var(--color-faint);
    font-family: var(--font-mono);
    margin-bottom: 0.5rem;
  }

  .post-content p {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--sp-s);
    margin-block: var(--sp-l) 0;
  }

  .quick-link-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    min-height: 150px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-main);
    transition:
      background 0.2s,
      border-color 0.2s;
  }

  .quick-link-card:hover {
    background: var(--color-surface-high);
    border-color: var(--color-theme);
    color: var(--color-theme);
  }

  .quick-link-card .icon {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    opacity: 0.8;
  }

  .quick-link-card h3 {
    font-size: 1.2rem;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .hero-container { min-height: 330px; }
    .hero-card { padding-left: 28px; }
    .hero-title { font-size: clamp(2.4rem, 12vw, 3.2rem); }
    .hero-card::before { font-size: 2rem; }
    .post-list,
    .quick-links { grid-template-columns: 1fr; }
    .section-header { align-items: flex-end; gap: 16px; }
  }
</style>
