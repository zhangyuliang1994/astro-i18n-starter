---
import { LOCALES, useTranslations, type Lang } from "@/i18n";
import Layout from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import PageHeadline from "@/components/PageHeadline.astro";
import Pagination from "@/components/Pagination.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("blog");
  
  // 为每种语言生成分页路径
  return Object.keys(LOCALES).flatMap((lang) => {
    const posts = allPosts
      .filter((post) => post.id.split("/")[0] === lang)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()); // 按日期降序排列
    
    return paginate(posts, {
      params: { lang },
      pageSize: 10,
    });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = Astro.params.lang as Lang;
const t = useTranslations(locale);

const title = t({
  ja: "ブログ",
  en: "Blog",
  "zh-cn": "博客",
  ar: "مدونة",
});

const pageTitle = page.currentPage > 1 
  ? `${title} - ${t({ ja: "ページ", en: "Page", "zh-cn": "第", ar: "صفحة" })} ${page.currentPage}`
  : title;

const description = t({
  en: "Technical notes, SEO strategies, and practical lessons from building products for global markets.",
  "zh-cn": "分享技术难题、SEO 策略，以及出海建站的实践经验。",
});
---

<Layout title={pageTitle} {description}>
  <PageHeadline {title} />

  <p>
    {
      description
    }
  </p>

  <ul>
    {
      page.data.map((post) => {
        const [, ...id] = post.id.split("/");
        return (
          <li>
            <a href={`/${locale}/blog/${id.join("/")}/`} class="blog-row">
              {post.data.cover && (
                <div class="blog-cover"><Image src={post.data.cover} alt={post.data.title} /></div>
              )}
              <div class="blog-copy">
                <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString(locale)}</time>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>

  <Pagination page={page} lang={locale} />
</Layout>

<style>
  :global(main) > p {
    margin-block-start: var(--sp-s);
  }
  ul {
    margin-block-start: var(--sp-m);
    display: grid;
    gap: 0;
  }

  li {
    border-bottom: 1px solid var(--color-border);
  }
  .blog-row {
    display: grid;
    grid-template-columns: minmax(180px, 28%) 1fr;
    gap: 28px;
    padding-block: 28px;
    color: inherit;
  }
  .blog-row:hover h2 { color: var(--color-theme); }
  .blog-cover { aspect-ratio: 16 / 10; overflow: hidden; border-radius: var(--radius-small); background: var(--color-code); }
  .blog-cover img { width: 100%; height: 100%; object-fit: cover; }
  .blog-copy time { color: var(--color-faint); font-family: var(--font-mono); font-size: 0.78rem; }
  .blog-copy h2 { margin-top: 8px; font-size: clamp(1.25rem, 3vw, 1.75rem); }
  .blog-copy p { margin-top: 10px; color: var(--color-muted); font-size: 0.95rem; line-height: 1.65; }
  @media (max-width: 640px) {
    .blog-row { grid-template-columns: 1fr; gap: 18px; }
    .blog-cover { aspect-ratio: 16 / 9; }
  }
</style>
