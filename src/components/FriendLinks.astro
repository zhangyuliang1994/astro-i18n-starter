---
import { useTranslations, type Lang } from "@/i18n";
import { FRIEND_LINKS, type FriendLink } from "@/consts";
const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);
---

<div class="friend-links">
  {FRIEND_LINKS.map((link: FriendLink) => (
    <a href={link.url} class="friend-card" target="_blank" rel="noopener noreferrer">
      <div class="avatar-wrapper">
        <img src={link.avatar} alt={typeof link.name === "string" ? link.name : t(link.name)} class="avatar" loading="lazy" />
      </div>
      <div class="card-info">
        <span class="external" aria-hidden="true">↗</span>
        <h3 class="friend-name">{typeof link.name === "string" ? link.name : t(link.name)}</h3>
        <p class="friend-description">{typeof link.description === "string" ? link.description : t(link.description)}</p>
        <span class="domain">{new URL(link.url).hostname}</span>
      </div>
    </a>
  ))}
</div>

<style>
  .friend-links { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-block-start: 48px; }
  .friend-card {
    position: relative;
    display: flex;
    min-height: 180px;
    gap: 20px;
    padding: 24px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-main);
  }
  .friend-card:hover { border-color: var(--color-theme); background: var(--color-surface-high); }
  .avatar-wrapper { flex: 0 0 auto; }
  .avatar { width: 56px; height: 56px; border: 1px solid var(--color-border); border-radius: var(--radius-small); background: var(--color-surface-high); object-fit: cover; }
  .card-info { min-width: 0; }
  .external { position: absolute; top: 18px; right: 20px; color: var(--color-faint); font-family: var(--font-mono); }
  .friend-name { padding-right: 26px; font-size: 1.2rem; }
  .friend-description { margin-top: 10px; color: var(--color-muted); font-size: 0.9rem; line-height: 1.55; }
  .domain { display: block; margin-top: 14px; color: var(--color-faint); font-family: var(--font-mono); font-size: 0.7rem; overflow-wrap: anywhere; }
  @media (max-width: 760px) { .friend-links { grid-template-columns: 1fr; } }
  @media (max-width: 420px) { .friend-card { min-height: 0; padding: 20px; } .avatar { width: 48px; height: 48px; } }
</style>
