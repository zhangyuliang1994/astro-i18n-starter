---
// Displays a link to the user's system language page
// if the language being viewed is different

import { LOCALES, type Lang } from "@/i18n";
const currentLocale = Astro.currentLocale as Lang;
const suggestionPrefix = currentLocale === "zh-cn" ? "切换至" : "View in";
const closeLabel = currentLocale === "zh-cn" ? "关闭语言建议" : "Dismiss language suggestion";
---

<div id="js-languageSuggest">
  <a id="js-link" href="#">
    <span class="material-icons-sharp" aria-hidden="true">autorenew</span>
    <span id="js-linkText"></span>
  </a>

  <button id="js-close" type="button" aria-label={closeLabel}>
    <span class="material-icons-sharp" aria-hidden="true">close</span>
  </button>
</div>

<script is:inline define:vars={{ currentLocale, LOCALES, suggestionPrefix }}>
  const browserLang = navigator.language.toLowerCase();
  const suggest = document.getElementById("js-languageSuggest");

  const showSuggest = (lang) => {
    const pathnames = location.pathname.split("/");
    const link = document.getElementById("js-link");
    const linkText = document.getElementById("js-linkText");

    pathnames[1] = lang;
    link.href = pathnames.join("/");
    linkText.innerText = `${suggestionPrefix} ${LOCALES[lang].label}`;
    suggest.style.display = "block";
  };

  if (
    currentLocale === browserLang ||
    currentLocale === browserLang.split("-")[0] ||
    localStorage.languageSuggestDenied ||
    localStorage.selectedLang
  ) {
    return;
  } else if (Object.keys(LOCALES).includes(browserLang)) {
    showSuggest(browserLang);
  } else if (Object.keys(LOCALES).includes(browserLang.split("-")[0])) {
    showSuggest(browserLang.split("-")[0]);
  }

  document.getElementById("js-close").addEventListener("click", () => {
    suggest.style.display = "none";
    localStorage.languageSuggestDenied = true;
  });
</script>

<style>
  #js-languageSuggest {
    min-height: 36px;
    display: none;
    position: relative;
    text-align: center;
    border-block-end: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-muted);
    font-family: var(--font-interface);
    font-size: 0.85rem;
  }
  #js-link {
    display: inline-flex;
    min-height: 36px;
    align-items: center;
    gap: 0.35rem;
    padding-inline: 3rem;
    color: inherit;
  }
  #js-link:hover {
    color: var(--color-theme);
  }
  #js-link .material-icons-sharp {
    font-size: 1rem;
  }
  #js-close {
    position: absolute;
    inset-block: 0;
    inset-inline-end: 0;
    display: grid;
    width: 36px;
    place-items: center;
    color: inherit;
    opacity: 0.65;
  }
  #js-close:hover {
    color: var(--color-main);
    opacity: 1;
  }
  #js-close .material-icons-sharp {
    font-size: 1.1rem;
  }
</style>
