---
interface Props { title: string; }
const { title } = Astro.props;
---

<header class="page-headline">
  <span class="eyebrow" aria-hidden="true">/</span>
  <h1>{title}</h1>
  <slot />
</header>

<style>
  .page-headline {
    position: relative;
    max-width: 900px;
    padding-block: 0 40px;
    border-bottom: 1px solid var(--color-border);
    text-align: start;
  }
  .eyebrow {
    display: block;
    margin-bottom: 12px;
    color: var(--color-theme);
    font-family: var(--font-mono);
    font-weight: 700;
  }
  h1 {
    color: var(--color-main);
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.055em;
    line-height: 1;
  }
  .page-headline :global(p) {
    max-width: 680px;
    margin-top: 20px;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  @media (max-width: 640px) {
    .page-headline { padding-block-end: 28px; }
    h1 { font-size: clamp(2.5rem, 14vw, 3.7rem); }
  }
</style>
