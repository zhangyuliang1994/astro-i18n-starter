---
import LocalesHomeList from "@/components/i18n/LocalesHomeList.astro";
import { useTranslations, type Lang } from "@/i18n";
const t = useTranslations(Astro.currentLocale as Lang);
---

<footer class="site-footer">
  <div class="footer-inner l-content">
    <div class="footer-primary">
      <div class="footer-tagline">
        {t({ ja: "✨ インスピレーションを記録し、思考を沈殿させる", en: "✨ Capture inspiration, cultivate thoughts", "zh-cn": "✨ 记录灵感，沉淀思考", ar: "✨ التقاط الإلهام، زراعة الأفكار" })}
      </div>
      <div class="copy">
        {t({ en: "©2024 - 2025 By frency", "zh-cn": "©2024 - 2026 By xiaofeng", ja: "©2024 - 2026 By xiaofeng", ar: "©2024 - 2026 By xiaofeng" })}
      </div>
    </div>
    <div class="footer-secondary">
      <ul class="locale-list"><LocalesHomeList /></ul>
      <div class="icp-info">
        <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">苏ICP备2023046043号-3</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 94%, transparent);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    padding-block: 40px;
  }
  .footer-primary,
  .footer-secondary { display: grid; gap: 12px; }
  .footer-secondary { justify-items: end; text-align: end; }
  .footer-tagline { font-weight: 600; color: var(--color-main); }
  .copy,
  .icp-info { color: var(--color-faint); font-family: var(--font-mono); font-size: 0.75rem; }
  .icp-info a:hover { color: var(--color-theme); }
  .locale-list { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 8px 18px; }
  .locale-list :global(a) {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .locale-list :global(a:hover) { color: var(--color-theme); }
  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; gap: 28px; padding-block: 32px; }
    .footer-secondary { justify-items: start; text-align: start; }
    .locale-list { justify-content: flex-start; }
  }
</style>
