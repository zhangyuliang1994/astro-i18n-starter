---
import LocaleSelect from "@/components/i18n/LocaleSelect.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { useTranslations, type Lang } from "@/i18n";
import { getRelativeLocaleUrl } from "astro:i18n";
import { SITE_TITLE } from "@/consts";

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);
const path = Astro.url.pathname.replace(/^\/[a-zA-Z-]+/, "").replace(/\/$/, "") || "/";
const isActive = (href: string) => href === "/" ? path === "/" : path === href || path.startsWith(`${href}/`);

const links = [
  { href: "/blog", label: t({ ja: "ブログ", en: "Blog", "zh-cn": "博客", ar: "مدونة" }) },
  { href: "/tags", label: t({ ja: "タグ", en: "Tags", "zh-cn": "标签", ar: "الوسوم" }) },
  { href: "/categories", label: t({ ja: "カテゴリー", en: "Categories", "zh-cn": "分类", ar: "التصنيفات" }) },
  { href: "/projects", label: t({ ja: "プロジェクト", en: "Projects", "zh-cn": "项目", ar: "مشاريع" }) },
  { href: "/about", label: t({ ja: "約", en: "About", "zh-cn": "关于", ar: "حول" }) },
  { href: "/friends", label: t({ ja: "友達", en: "Friends", "zh-cn": "友链", ar: "أصدقاء" }) },
];

const menuLabel = t({ en: "Open navigation", "zh-cn": "打开导航", ja: "ナビゲーションを開く", ar: "فتح التنقل" });
---

<header class="site-header">
  <div class="header-inner l-content">
    <a class="brand" href={getRelativeLocaleUrl(locale, "/")} aria-label={t({ en: "Home", "zh-cn": "首页", ja: "ホーム", ar: "الرئيسية" })}>
      <span class="brand-mark" aria-hidden="true">/</span>
      <span class="brand-name">{t(SITE_TITLE)}</span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {links.map((link) => (
        <a href={getRelativeLocaleUrl(locale, link.href)} class:list={{ active: isActive(link.href) }} aria-current={isActive(link.href) ? "page" : undefined}>
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-tools">
      <div class="desktop-locale"><LocaleSelect /></div>
      <ThemeToggle />
      <details class="mobile-menu">
        <summary aria-label={menuLabel}>
          <span class="material-icons-sharp" aria-hidden="true">menu</span>
        </summary>
        <div class="mobile-panel">
          <nav aria-label="Mobile navigation">
            {links.map((link) => (
              <a href={getRelativeLocaleUrl(locale, link.href)} class:list={{ active: isActive(link.href) }} aria-current={isActive(link.href) ? "page" : undefined}>
                {link.label}
              </a>
            ))}
          </nav>
          <LocaleSelect />
        </div>
      </details>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 50;
    top: 0;
    height: 65px;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-base) 88%, transparent);
    backdrop-filter: blur(14px);
  }

  .header-inner {
    display: grid;
    grid-template-columns: minmax(150px, 1fr) auto minmax(150px, 1fr);
    align-items: center;
    height: 64px;
  }

  .brand {
    display: inline-flex;
    justify-self: start;
    align-items: center;
    gap: 9px;
    min-width: 0;
  }

  .brand-mark {
    color: var(--color-theme);
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .brand-name {
    color: var(--color-main);
    font-family: var(--font-interface);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.035em;
  }

  .desktop-nav {
    display: flex;
    align-self: stretch;
    align-items: center;
    gap: clamp(16px, 2.1vw, 28px);
  }

  .desktop-nav a {
    position: relative;
    display: flex;
    align-items: center;
    height: 100%;
    color: var(--color-muted);
    font-family: var(--font-interface);
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .desktop-nav a::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 2px;
    background: transparent;
  }

  .desktop-nav a:hover,
  .desktop-nav a.active { color: var(--color-theme); }
  .desktop-nav a.active::after { background: var(--color-theme); }

  .header-tools {
    display: flex;
    justify-self: end;
    align-items: center;
    gap: 4px;
  }

  .mobile-menu { display: none; }

  @media (max-width: 960px) {
    .header-inner { grid-template-columns: 1fr auto; }
    .desktop-nav,
    .desktop-locale { display: none; }
    .mobile-menu { display: block; }
    .mobile-menu summary {
      display: grid;
      width: 44px;
      height: 44px;
      place-items: center;
      border-radius: var(--radius-small);
      color: var(--color-muted);
      cursor: pointer;
      list-style: none;
    }
    .mobile-menu summary::-webkit-details-marker { display: none; }
    .mobile-menu[open] summary { color: var(--color-theme); background: var(--color-surface); }
    .mobile-panel {
      position: absolute;
      top: 64px;
      right: 0;
      left: 0;
      padding: 16px 20px 20px;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-surface-high);
    }
    .mobile-panel nav { display: grid; }
    .mobile-panel nav a {
      display: flex;
      min-height: 48px;
      align-items: center;
      border-bottom: 1px solid var(--color-border);
      color: var(--color-muted);
      font-weight: 600;
    }
    .mobile-panel nav a.active { color: var(--color-theme); }
    .mobile-panel :global(label) { margin-top: 16px; }
  }

  @media (max-width: 420px) {
    .brand-name { font-size: 1.12rem; }
    .brand { gap: 6px; }
  }
</style>
