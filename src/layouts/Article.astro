---
import Base from "@/layouts/Base.astro";
import BackToTop from "@/components/BackToTop.astro";

interface Props { title?: string; description?: string; frontmatter?: undefined; }
const { title, description } = Astro.props.frontmatter || Astro.props;
---

<Base {title} {description}>
  <article class="article-shell"><slot /></article>
  <BackToTop />
</Base>

<style>
  .article-shell {
    max-width: var(--reading);
    margin-inline: auto;
    padding: clamp(24px, 5vw, 48px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface-high);
    font-size: 1.075rem;
    line-height: 1.82;
  }
  article > * { margin-block: 1.35em 0; margin-inline: 0; }
  article > :first-child { margin-top: 0; }
  article p { color: var(--color-main); font-weight: 400; }
  article h2 { margin-block: 2.8em 0; padding-block-end: 0.35em; border-bottom: 1px solid var(--color-border); font-size: 1.65rem; }
  article h3 { margin-block: 2.2em 0; font-size: 1.35rem; }
  article h4 { margin-block: 2em -0.4em; font-size: 1.1rem; }
  article ul { list-style: disc; padding-inline-start: 1.5em; }
  article ol { list-style: decimal; padding-inline-start: 1.5em; }
  article li { margin-block-end: 0.55em; }
  article table { display: block; overflow-x: auto; table-layout: auto; }
  article th,
  article td { min-width: 120px; padding: 0.65em 0.8em; border: 1px solid var(--color-border); }
  article th { background: var(--color-code); text-align: start; }
  article strong { text-decoration: underline; text-decoration-color: color-mix(in srgb, var(--color-theme) 35%, transparent); text-decoration-thickness: 0.2em; text-underline-offset: -0.05em; }
  article :not(pre) > code { padding: 0.2em 0.4em; border-radius: 4px; background: var(--color-code); color: var(--color-theme); font-family: var(--font-mono); font-size: 0.9em; }
  article pre { max-width: 100%; overflow-x: auto; padding: 1.1em; border: 1px solid var(--color-border-strong); border-radius: var(--radius-small); background: var(--color-code) !important; font-family: var(--font-mono); font-size: 0.88rem; line-height: 1.65; }
  article blockquote { padding: 1.1em 1.25em; border-left: 3px solid var(--color-theme); background: var(--color-code); color: var(--color-muted); }
  article hr { margin-block: 4em 3em; border: 0; border-top: 1px solid var(--color-border); }
  article a { color: var(--color-theme); text-decoration: underline; text-underline-offset: 0.18em; }
  article img,
  article video { max-width: 100%; border-radius: var(--radius-small); background: var(--color-code); }
  article iframe { max-width: 100%; }
  article iframe[src*="youtube"],
  article iframe[src*="vimeo"] { width: 100%; height: auto; aspect-ratio: 16 / 9; border-radius: var(--radius-small); }
  article details { padding: 16px; border: 1px solid var(--color-border); border-radius: var(--radius-small); background: var(--color-surface); }
  article summary { min-height: 44px; cursor: pointer; font-weight: 600; }
  @media (max-width: 640px) {
    .article-shell { margin-inline: -4px; padding: 22px 18px; border-right: 0; border-left: 0; border-radius: 0; font-size: 1.0625rem; }
    article h2 { font-size: 1.45rem; }
  }
</style>
